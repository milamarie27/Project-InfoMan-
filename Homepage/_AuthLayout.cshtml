<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CTUG Online Clearance – @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #111;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-frame {
            width: 900px;
            min-height: 520px;
            display: flex;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        /* LEFT PANEL */
        .auth-left {
            width: 43%;
            background: #1a4731;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px 36px;
            text-align: center;
            gap: 24px;
        }
        .auth-logo-group {
            display: flex;
            align-items: center;
            gap: 0;
        }
        .auth-logo-circle {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: #c9a84c;
            display: flex; align-items: center; justify-content: center;
            font-size: 26px; font-weight: 900; color: #1a4731;
            border: 3px solid rgba(255,255,255,0.25);
            overflow: hidden;
        }
        .auth-logo-circle img { width: 100%; height: 100%; object-fit: cover; }
        .auth-logo-divider {
            width: 2px; height: 52px;
            background: rgba(255,255,255,0.35);
            margin: 0 14px;
        }
        .auth-logo-ctu {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: #7a1515;
            display: flex; align-items: center; justify-content: center;
            font-size: 9px; font-weight: 700; color: white;
            border: 3px solid rgba(255,255,255,0.25);
            overflow: hidden;
        }
        .auth-logo-ctu img { width: 100%; height: 100%; object-fit: cover; }
        .auth-left h2 {
            font-size: 18px;
            font-weight: 700;
            color: white;
            line-height: 1.4;
        }

        /* RIGHT PANEL */
        .auth-right {
            flex: 1;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 48px 48px;
            position: relative;
        }
        .back-link {
            position: absolute;
            top: 20px; left: 24px;
            font-size: 13px;
            color: #555;
            text-decoration: none;
            display: flex; align-items: center; gap: 4px;
            font-weight: 500;
        }
        .back-link:hover { color: #1a4731; }

        /* FORM ELEMENTS */
        .auth-title { font-size: 22px; font-weight: 800; color: #1a1a2e; margin-bottom: 6px; }
        .auth-sub { font-size: 13px; color: #888; margin-bottom: 24px; line-height: 1.5; }

        .form-label-sm {
            font-size: 12px;
            font-weight: 600;
            color: #444;
            margin-bottom: 5px;
            display: block;
        }
        .form-input {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            padding: 10px 13px;
            font-size: 13px;
            font-family: inherit;
            color: #1a1a2e;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: white;
        }
        .form-input:focus {
            border-color: #1a4731;
            box-shadow: 0 0 0 3px rgba(26,71,49,0.12);
        }
        select.form-input { appearance: none; cursor: pointer; }
        .select-wrapper { position: relative; }
        .select-wrapper::after {
            content: '▼';
            font-size: 9px;
            color: #888;
            position: absolute;
            right: 13px; top: 50%;
            transform: translateY(-50%);
            pointer-events: none;
        }

        .btn-primary-green {
            width: 100%;
            background: #28a745;
            color: white;
            border: none;
            border-radius: 6px;
            padding: 12px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            font-family: inherit;
            transition: background 0.2s, transform 0.1s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-primary-green:hover { background: #218838; }
        .btn-primary-green:active { transform: scale(0.99); }

        .form-check-sm {
            display: flex; align-items: center; gap: 8px;
            font-size: 13px; color: #555;
        }
        .form-check-sm input[type="checkbox"] {
            width: 15px; height: 15px; accent-color: #28a745;
        }

        /* ROLE RADIO */
        .role-option {
            border: 1.5px solid #d1d5db;
            border-radius: 7px;
            padding: 13px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s;
            margin-bottom: 12px;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.5px;
            color: #444;
        }
        .role-option:hover { border-color: #1a4731; background: #f0faf4; }
        .role-option input[type="radio"] { accent-color: #28a745; width: 17px; height: 17px; }
        .role-option.selected { border-color: #28a745; background: #f0faf4; }

        /* VALIDATION */
        .field-error { font-size: 11px; color: #dc3545; margin-top: 4px; }
        .alert-danger-sm {
            background: #fff5f5; border: 1px solid #f5c2c7;
            border-radius: 6px; padding: 10px 14px;
            font-size: 13px; color: #842029; margin-bottom: 16px;
        }

        @media (max-width: 640px) {
            .auth-frame { flex-direction: column; width: 98vw; }
            .auth-left { width: 100%; padding: 32px 24px; }
            .auth-right { padding: 32px 24px; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="auth-frame">
        <!-- LEFT -->
        <div class="auth-left">
            <div class="auth-logo-group">
                <div class="auth-logo-circle">
                    <!-- <img src="~/images/ginatilan-logo.png" alt="Ginatilan Logo" /> -->
                    <span>g</span>
                </div>
                <div class="auth-logo-divider"></div>
                <div class="auth-logo-ctu">
                    <!-- <img src="~/images/ctu-logo.png" alt="CTU Logo" /> -->
                    <span>CTU</span>
                </div>
            </div>
            <h2>Cebu Technological University Of Ginatilan – Online Clearance</h2>
        </div>

        <!-- RIGHT -->
        <div class="auth-right">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
