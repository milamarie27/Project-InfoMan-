@{
    ViewData["Title"] = "Welcome";
    Layout = null; // Full-page, no shared layout
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CTUG Online Clearance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #111;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .landing-frame {
            width: 930px;
            min-height: 530px;
            background: #1a4731;
            border-radius: 6px;
            border: 2px solid #c9a84c;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
        }

        /* TOP NAV */
        .top-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 28px 0;
        }
        .brand-dot {
            display: flex;
            align-items: center;
            gap: 8px;
            color: white;
            font-weight: 700;
            font-size: 14px;
        }
        .brand-dot::before {
            content: '';
            width: 9px; height: 9px;
            background: #c9a84c;
            border-radius: 50%;
            display: inline-block;
        }
        .nav-links { display: flex; gap: 28px; }
        .nav-links a {
            color: rgba(255,255,255,0.85);
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: white; }

        /* HERO */
        .hero {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 40px 60px;
        }
        .logo-group {
            display: flex;
            align-items: center;
            gap: 0;
            margin-bottom: 28px;
        }
        .logo-circle {
            width: 80px; height: 80px;
            border-radius: 50%;
            background: #c9a84c;
            display: flex; align-items: center; justify-content: center;
            font-size: 32px; font-weight: 800; color: #1a4731;
            border: 3px solid rgba(255,255,255,0.3);
            overflow: hidden;
        }
        .logo-circle img { width: 100%; height: 100%; object-fit: cover; }
        .logo-divider {
            width: 2px; height: 60px;
            background: rgba(255,255,255,0.4);
            margin: 0 16px;
        }
        .logo-circle-ctu {
            width: 80px; height: 80px;
            border-radius: 50%;
            background: #8b1a1a;
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; color: white; text-align: center;
            border: 3px solid rgba(255,255,255,0.3);
            padding: 8px;
            overflow: hidden;
        }
        .logo-circle-ctu img { width: 100%; height: 100%; object-fit: cover; }

        .hero h1 {
            font-size: 28px;
            font-weight: 800;
            color: white;
            line-height: 1.3;
            margin-bottom: 16px;
            max-width: 560px;
        }
        .hero p {
            font-size: 14px;
            color: rgba(255,255,255,0.75);
            line-height: 1.7;
            max-width: 460px;
            margin-bottom: 36px;
        }
        .btn-get-started {
            background: transparent;
            border: 1.5px solid rgba(255,255,255,0.8);
            color: white;
            border-radius: 24px;
            padding: 11px 28px;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            transition: all 0.25s;
            cursor: pointer;
        }
        .btn-get-started:hover {
            background: white;
            color: #1a4731;
        }
        .btn-get-started .arrow {
            font-size: 16px;
            transition: transform 0.2s;
        }
        .btn-get-started:hover .arrow { transform: translateX(4px); }

        /* FOOTER */
        .landing-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 28px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        .landing-footer span {
            font-size: 11px;
            color: rgba(255,255,255,0.5);
        }
        .portal-status {
            display: flex; align-items: center; gap: 6px;
            font-size: 11px;
            color: rgba(255,255,255,0.7);
        }
        .portal-status::before {
            content: '';
            width: 7px; height: 7px;
            background: #4ade80;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 6px #4ade80;
        }

        @media (max-width: 600px) {
            .landing-frame { width: 98vw; min-height: unset; }
            .hero { padding: 32px 24px; }
            .hero h1 { font-size: 20px; }
        }
    </style>
</head>
<body>
    <div class="landing-frame">
        <!-- NAV -->
        <nav class="top-nav">
            <div class="brand-dot">CTU – Ginatilan</div>
            <div class="nav-links">
                <a href="#">About</a>
                <a href="#">Help</a>
                <a href="#">Contact</a>
            </div>
        </nav>

        <!-- HERO -->
        <div class="hero">
            <div class="logo-group">
                <div class="logo-circle">
                    <!-- Replace src with actual logo path: ~/images/ginatilan-logo.png -->
                    <span style="font-size:28px;font-weight:900;">g</span>
                </div>
                
            </div>

            <h1>Cebu Technological University - Ginatilan<br />Extension Campus - Online Clearance</h1>
            <p>
                A faster, paperless way to complete your school clearance.
                Track requirements, get signed off, and download your clearance – all in one place.
            </p>

            <a href="/Account/Login" class="btn-get-started">
                Get Started <span class="arrow">→</span>
            </a>
        </div>

        <!-- FOOTER -->
        <footer class="landing-footer">
            <span>Cebu Technological University — Ginatilan Campus · All rights reserved</span>
            <span class="portal-status">Portal is open</span>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
