@{
    string userName    = ViewData["UserName"]?.ToString()      ?? "Student";
    string userId      = ViewData["UserId"]?.ToString()        ?? "";
    string userCourse  = ViewData["UserCourse"]?.ToString()    ?? "BSIT";
    string userYear    = ViewData["UserYear"]?.ToString()      ?? "2nd Year";
    string activePage  = ViewData["ActivePage"]?.ToString()    ?? "Dashboard";
    bool   showOrg     = ViewData["ShowOrg"] is true;          // Staff additional role
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CTUG Clearance – @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        :root {
            --green: #1a4731;
            --green-mid: #246040;
            --green-accent: #28a745;
            --green-light: #34c759;
            --red: #dc3545;
            --gold: #c9a84c;
            --muted: rgba(255,255,255,0.58);
            --border: #e9ecef;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f4f6f8; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

        /* ── HEADER ── */
        .top-header { background: var(--green); color: white; padding: 0 20px; height: 52px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
        .brand { display: flex; align-items: center; gap: 11px; }
        .brand-icon { width: 32px; height: 32px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; }
        .brand-icon i { color: var(--green); font-size: 15px; }
        .brand-text .school  { font-weight: 700; font-size: 13px; }
        .brand-text .system  { font-size: 11px; color: var(--muted); }
        .header-right { display: flex; align-items: center; gap: 12px; }
        .course-badge { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 20px; padding: 4px 14px; font-size: 12px; font-weight: 700; color: white; }
        .notif-btn { background: none; border: none; color: white; font-size: 17px; cursor: pointer; position: relative; }
        .notif-dot { position: absolute; top: -3px; right: -3px; background: var(--red); border-radius: 50%; width: 7px; height: 7px; }
        .icon-btn { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 17px; cursor: pointer; }

        /* ── LAYOUT ── */
        .layout { display: flex; flex: 1; overflow: hidden; }

        /* ── SIDEBAR ── */
        .sidebar { width: 210px; background: var(--green); display: flex; flex-direction: column; flex-shrink: 0; overflow-y: auto; padding: 16px 0 12px; }
        .sb-profile { padding: 0 16px 14px; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 6px; }
        .sb-avatar { width: 50px; height: 50px; border-radius: 50%; background: rgba(255,255,255,0.18); display: flex; align-items: center; justify-content: center; font-size: 20px; color: white; }
        .sb-name { font-weight: 700; font-size: 12px; color: white; line-height: 1.3; }
        .sb-sub  { font-size: 11px; color: var(--muted); }
        .sb-divider { border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 2px 14px; }
        .sb-section { font-size: 10px; font-weight: 700; letter-spacing: 1.4px; color: var(--muted); text-transform: uppercase; padding: 10px 18px 4px; }
        .nav-link-item { display: flex; align-items: center; gap: 9px; padding: 9px 18px; color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 500; transition: all 0.18s; border-left: 3px solid transparent; }
        .nav-link-item:hover { background: rgba(255,255,255,0.08); color: white; }
        .nav-link-item.active { background: rgba(255,255,255,0.13); color: white; border-left-color: var(--green-light); }
        .nav-link-item i { width: 16px; text-align: center; font-size: 13px; }
        .sb-footer { margin-top: auto; padding: 12px 14px; }
        .sb-year { text-align: center; font-size: 11px; color: var(--muted); margin-top: 6px; }
        .btn-logout { width: 100%; background: rgba(255,255,255,0.09); border: 1px solid rgba(255,255,255,0.18); color: white; border-radius: 8px; padding: 7px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; }
        .btn-logout:hover { background: rgba(220,53,69,0.28); border-color: var(--red); }

        /* ── MAIN ── */
        .main { flex: 1; overflow-y: auto; padding: 24px; }

        /* ── SHARED COMPONENTS ── */
        .welcome-card { background: var(--green); border-radius: 12px; padding: 22px 28px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; }
        .welcome-card h4 { font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.75); margin-bottom: 4px; }
        .welcome-card h2 { font-size: 22px; font-weight: 800; color: white; }
        .period-box { background: rgba(255,255,255,0.13); border-radius: 10px; padding: 10px 16px; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
        .period-icon { width: 36px; height: 36px; background: rgba(255,255,255,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
        .period-icon i { color: white; font-size: 15px; }
        .period-label { font-size: 11px; color: rgba(255,255,255,0.65); }
        .period-value { font-size: 13px; font-weight: 700; color: white; }
        .active-badge { background: var(--green-accent); color: white; border-radius: 20px; padding: 3px 12px; font-size: 11px; font-weight: 700; }

        .stat-card { background: white; border-radius: 12px; padding: 18px; display: flex; align-items: center; gap: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); height: 100%; }
        .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; position: relative; }
        .stat-icon.green  { background: #e6f4ea; color: var(--green-accent); }
        .stat-icon.orange { background: #fef3e2; color: #e37400; }
        .stat-icon.blue   { background: #e8f0fe; color: #1a73e8; }
        .stat-dot { position: absolute; top: -3px; right: -3px; width: 14px; height: 14px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 8px; font-weight: 900; color: white; }
        .stat-dot.ok  { background: var(--green-accent); }
        .stat-dot.bad { background: var(--red); }
        .stat-num   { font-size: 24px; font-weight: 800; color: #1a1a2e; line-height: 1; }
        .stat-label { font-size: 12px; font-weight: 600; color: #333; }
        .stat-sub   { font-size: 11px; color: #888; }

        .page-card { background: white; border-radius: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); overflow: hidden; }
        .page-card-hd { background: var(--green-accent); color: white; padding: 12px 20px; font-size: 15px; font-weight: 700; }
        .page-card-hd.dark { background: var(--green); }

        .data-table { width: 100%; border-collapse: collapse; }
        .data-table thead th { background: #f8f9fa; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.7px; color: #666; padding: 10px 16px; text-align: left; border-bottom: 2px solid var(--border); }
        .data-table tbody td { padding: 11px 16px; font-size: 13px; color: #333; border-bottom: 1px solid var(--border); vertical-align: middle; }
        .data-table tbody tr:last-child td { border-bottom: none; }
        .data-table tbody tr:hover { background: #fafafa; }
        .code-badge { background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px; padding: 4px 10px; font-size: 12px; font-weight: 700; color: #495057; display: inline-block; }
        .status-approved { color: var(--green-accent); font-weight: 600; font-size: 12px; }
        .status-approved::before { content: "●"; margin-right: 4px; }
        .status-pending  { color: #e37400; font-weight: 600; font-size: 12px; }
        .status-pending::before  { content: "●"; margin-right: 4px; }

        .checklist-item { display: flex; align-items: flex-start; gap: 11px; padding: 12px 18px; border-bottom: 1px solid var(--border); }
        .checklist-item:last-child { border-bottom: none; }
        .check-box { width: 20px; height: 20px; border-radius: 5px; background: var(--green-accent); color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 10px; margin-top: 2px; }
        .check-title { font-weight: 600; font-size: 13px; color: #1a1a2e; }
        .check-desc  { font-size: 11px; color: #888; line-height: 1.5; }

        .ann-tab { border-radius: 20px; padding: 5px 15px; font-size: 12px; font-weight: 700; border: 1.5px solid #dee2e6; background: white; color: #555; cursor: pointer; transition: all 0.18s; }
        .ann-tab.active { background: var(--green-accent); color: white; border-color: var(--green-accent); }
        .ann-card { background: white; border-radius: 10px; padding: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); margin-bottom: 10px; }
        .ann-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--green); color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; }
        .ann-tag { border-radius: 20px; padding: 2px 9px; font-size: 10px; font-weight: 700; }
        .tag-pinned { background: #e3f2fd; color: #1565c0; }
        .tag-urgent { background: #ffebee; color: #c62828; }
        .tag-event  { background: #e8f5e9; color: #2e7d32; }
        .btn-green { background: var(--green-accent); color: white; border: none; border-radius: 8px; padding: 10px 32px; font-size: 14px; font-weight: 700; cursor: pointer; transition: background 0.2s; font-family: inherit; }
        .btn-green:hover { background: #218838; }
        .btn-dark  { background: #6c757d; color: white; border: none; border-radius: 8px; padding: 10px 32px; font-size: 14px; font-weight: 700; cursor: pointer; transition: background 0.2s; font-family: inherit; }
        .btn-dark:hover  { background: #5a6268; }
        .semester-badge { background: var(--green); color: white; border-radius: 8px; padding: 7px 14px; font-size: 12px; font-weight: 700; text-align: center; display: inline-block; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- HEADER -->
    <header class="top-header">
        <div class="brand">
            <div class="brand-icon"><i class="fas fa-graduation-cap"></i></div>
            <div class="brand-text">
                <div class="school">CTU – Ginatilan</div>
                <div class="system">Online Clearance</div>
            </div>
        </div>
        <div class="header-right">
            <span class="course-badge">@userCourse – @userYear</span>
            <button class="notif-btn" title="Notifications"><i class="fas fa-bell"></i><span class="notif-dot"></span></button>
            <button class="icon-btn" title="Settings"><i class="fas fa-th"></i></button>
        </div>
    </header>

    <div class="layout">
        <!-- SIDEBAR -->
        <nav class="sidebar">
            <div class="sb-profile">
                <div class="sb-avatar"><i class="fas fa-user"></i></div>
                <div class="sb-name">@userName</div>
                <div class="sb-sub">@userCourse · ID @userId</div>
            </div>
            <hr class="sb-divider" />

            <div class="sb-section">Main</div>
            <a href="/Student/Dashboard"       class="nav-link-item @(activePage=="Dashboard"?"active":"")"><i class="fas fa-th-large"></i><span>Dashboard</span></a>
            <a href="/Student/SubjectsOffered" class="nav-link-item @(activePage=="SubjectsOffered"?"active":"")"><i class="fas fa-book-open"></i><span>Subjects Offered</span></a>
            <a href="/Student/Clearance"       class="nav-link-item @(activePage=="Clearance"?"active":"")"><i class="fas fa-clipboard-list"></i><span>Clearance</span></a>
            @if (showOrg) {
                <a href="/Student/Organization" class="nav-link-item @(activePage=="Organization"?"active":"")"><i class="fas fa-sitemap"></i><span>Organization</span></a>
            }

            <div class="sb-section">Account</div>
            <a href="/Student/Profile"      class="nav-link-item @(activePage=="Profile"?"active":"")"><i class="fas fa-user-circle"></i><span>Profile</span></a>
            <a href="/Student/DownloadPdf"  class="nav-link-item @(activePage=="DownloadPdf"?"active":"")"><i class="fas fa-file-download"></i><span>Download PDF</span></a>

            <div class="sb-footer">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn-logout"><i class="fas fa-sign-out-alt"></i><span>Log-out</span></button>
                </form>
                <div class="sb-year">A.Y. 2025 – 2026</div>
            </div>
        </nav>

        <!-- MAIN -->
        <main class="main">@RenderBody()</main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
