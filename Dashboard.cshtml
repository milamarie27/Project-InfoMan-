@model OnlineClearance.Models.StudentDashboardViewModel
@{
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<!-- WELCOME BANNER -->
<div class="welcome-card mb-4">
    <div>
        <h4>Welcome,</h4>
        <h2>@(Model?.StudentName ?? "Althea Jean Barnes")!</h2>
    </div>
    <div class="period-box">
        <div class="period-icon"><i class="fas fa-calendar-alt"></i></div>
        <div>
            <div class="period-label">Active Academic Period</div>
            <div class="period-value">A.Y. 2025-2026, 2nd Semester</div>
        </div>
        <span class="active-badge">Active</span>
    </div>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon green">
                <i class="fas fa-clipboard-check"></i>
                <span class="stat-dot ok"><i class="fas fa-check"></i></span>
            </div>
            <div>
                <div class="stat-num">@(Model?.SubjectCleared ?? 3)<span style="font-size:16px;color:#888;">/8</span></div>
                <div class="stat-label">Subject Cleared</div>
                <div class="stat-sub">Total Subjects</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon orange">
                <i class="fas fa-clock"></i>
                <span class="stat-dot bad"><i class="fas fa-times"></i></span>
            </div>
            <div>
                <div class="stat-num">@(Model?.SubjectIncomplete ?? 0)</div>
                <div class="stat-label">Subject Incomplete</div>
                <div class="stat-sub">Across all enrolled subject</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon blue">
                <i class="fas fa-sitemap"></i>
            </div>
            <div>
                <div class="stat-num">@(Model?.OrgCleared ?? 0)<span style="font-size:16px;color:#888;">/7</span></div>
                <div class="stat-label">Organization Cleared</div>
                <div class="stat-sub">Across all Organization signatures</div>
            </div>
        </div>
    </div>
</div>

<!-- CHECKLIST + ANNOUNCEMENTS -->
<div class="row g-3">
    <!-- CHECKLIST -->
    <div class="col-md-5">
        <div class="page-card">
            <div style="background:var(--green);color:white;padding:13px 18px;display:flex;justify-content:space-between;align-items:center;">
                <span style="font-weight:700;font-size:14px;"><i class="fas fa-tasks me-2"></i>Clearance Checklist</span>
                <span style="background:var(--green-accent);border-radius:20px;padding:3px 12px;font-size:11px;font-weight:700;">5/5 Completed</span>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 1: Select Subject</div>
                    <div class="check-desc">Select your subjects you enrolled.</div>
                </div>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 2: Confirm Enrolled Subjects</div>
                    <div class="check-desc">Confirm your selected enrolled subjects, then submit to the assign Instructor.</div>
                </div>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 3: Subject Instructor's Approval</div>
                    <div class="check-desc">Wait for your Subject Instructors to sign your clearance</div>
                </div>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 4: Final Approval</div>
                    <div class="check-desc">Lastly, get approval from the Organization's Signatories</div>
                </div>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Final Check</div>
                    <div class="check-desc">Download and Print the pdf. Make sure all of the above are approved to proceed.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ANNOUNCEMENTS -->
    <div class="col-md-7">
        <div style="background:white;border-radius:12px;padding:18px;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
            <div class="d-flex gap-2 mb-3 flex-wrap">
                <button class="ann-tab active" onclick="filterAnn('all',this)">ALL</button>
                <button class="ann-tab" onclick="filterAnn('pinned',this)" style="background:#1a4731;color:white;border-color:#1a4731;"><i class="fas fa-thumbtack me-1"></i>PINNED</button>
                <button class="ann-tab" onclick="filterAnn('urgent',this)" style="background:#dc3545;color:white;border-color:#dc3545;">URGENT</button>
                <button class="ann-tab" onclick="filterAnn('event',this)" style="background:#0d6efd;color:white;border-color:#0d6efd;">EVENTS</button>
            </div>
            <div id="ann-list">
                <div class="ann-card" data-tag="pinned urgent">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <div class="ann-avatar">SA</div>
                            <div>
                                <div style="font-weight:700;font-size:12px;">System Administrator</div>
                                <div style="font-size:11px;color:#888;">April 15, 2026</div>
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <span class="ann-tag tag-pinned"><i class="fas fa-thumbtack me-1"></i>Pinned</span>
                            <span class="ann-tag tag-urgent">Urgent</span>
                        </div>
                    </div>
                    <div style="font-weight:700;font-size:13px;margin-bottom:6px;">Deadline for clearance submission — AY 2025-2026</div>
                    <div style="font-size:12px;color:#555;line-height:1.6;">
                        All students are required to complete their clearance requirements on or before
                        <span style="color:#dc3545;font-weight:700;">April 30, 2026</span>. Incomplete submissions will not be processed.
                        Please coordinate with your respective instructors immediately for any pending signatures.
                    </div>
                </div>
                <div class="ann-card" data-tag="event">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <div class="ann-avatar">SA</div>
                            <div>
                                <div style="font-weight:700;font-size:12px;">System Administrator</div>
                                <div style="font-size:11px;color:#888;">April 15, 2026</div>
                            </div>
                        </div>
                        <span class="ann-tag tag-event">Event</span>
                    </div>
                    <div style="font-weight:700;font-size:13px;margin-bottom:6px;">Enrollment for AY 2026-2027 opens May 5</div>
                    <div style="font-size:12px;color:#555;line-height:1.6;">The new academic year enrollment starts <span style="color:#dc3545;font-weight:700;">May 5, 2026</span>. Complete your clearance first.</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterAnn(tag, btn) {
    document.querySelectorAll('.ann-tab').forEach(b => { b.style.background='white'; b.style.color='#555'; b.style.borderColor='#dee2e6'; });
    btn.style.background='#28a745'; btn.style.color='white'; btn.style.borderColor='#28a745';
    document.querySelectorAll('#ann-list .ann-card').forEach(c => {
        c.style.display = tag === 'all' ? '' : (c.dataset.tag||'').includes(tag) ? '' : 'none';
    });
}
</script>
}
